{
  "name": "pumpsdk",
  "version": "2.0.0",
  "description": "MCP server for Pump.fun token trading and management",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "pumpsdk": "dist/src/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"const{cpSync,mkdirSync}=require('fs');mkdirSync('dist/src/signing',{recursive:true});cpSync('src/signing/page.html','dist/src/signing/page.html');cpSync('src/signing/scout-page.html','dist/src/signing/scout-page.html');cpSync('src/signing/dashboard.html','dist/src/signing/dashboard.html');cpSync('node_modules/@solana/web3.js/lib/index.iife.min.js','dist/src/signing/solana-web3.js')\"",
    "start": "node dist/src/index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@pump-fun/pump-sdk": "^1.31.0",
    "@solana/web3.js": "^1.98.4",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "grammy": "^1.41.1",
    "zod": "^3.25.7"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.17",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.8.3"
  }
}
