# Solana RPC endpoint (defaults to mainnet-beta public endpoint)
SOLANA_RPC_URL=

# Agent wallet public key (required for agent strategies)
AGENT_WALLET_PUBKEY=

# AI provider keys (at least one needed for agent mode)
ANTHROPIC_API_KEY=
NOUS_API_KEY=

# Image generation (optional — fal.ai or Replicate)
FAL_API_KEY=
REPLICATE_API_KEY=
IMAGE_GEN_PROVIDER=fal

# MCP HTTP transport auth token (optional)
MCP_HTTP_TOKEN=

# Telegram bot integration (optional — only needed if running the Telegram bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
WALLET_PUBKEY=
SIGNING_SERVER_URL=http://localhost:3142

# Agent strategy config (optional)
MONITOR_KEYWORDS=
SCOUT_SOURCES=pump
SCOUT_MAX_IDEAS=5
SCOUT_INTERVAL=60000
SNIPER_KEYWORDS=
SNIPER_MAX_BUY_SOL=0.01
SNIPER_SLIPPAGE=15

# Dev/debug flags (optional, set to "1" to enable)
PUMPSDK_DEV_NO_CSRF=
PUMPSDK_DEBUG_API=
PUMPSDK_NO_IMAGE_GEN=
PUMPSDK_AGENT_DRY_RUN=
PUMPSDK_DEVNET=
# PUMPSDK_SESSION_TTL=600000
PUMPSDK_SESSION_TTL=
PUMPSDK_NO_WS=
PUMPSDK_ENCRYPT_SESSIONS=
# Required when PUMPSDK_ENCRYPT_SESSIONS=1 — used to derive AES-256-GCM key
PUMPSDK_SESSION_KEY=
